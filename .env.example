# =============================================================================
# Copy this file to .env.local and fill in real values, then restart the dev server:
#   cp .env.example .env.local
#   npm run dev
# =============================================================================

# Supabase Configuration
# Project: https://supabase.com/dashboard/project/mbboakpdxgquntlohlix
# Keys: Project Settings → API (anon public + service_role — never commit real keys)
NEXT_PUBLIC_SUPABASE_URL=https://mbboakpdxgquntlohlix.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (auth redirects + email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LiveKit (video rooms + RoomComposite Egress recording)
# Dashboard: https://cloud.livekit.io → Project settings
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Supabase S3-compatible credentials (Storage → S3 Access Keys)
# Required for LiveKit Egress to upload into the private session-recordings bucket
SUPABASE_S3_ACCESS_KEY=your-supabase-s3-access-key
SUPABASE_S3_SECRET_KEY=your-supabase-s3-secret-key
# Optional overrides
# SUPABASE_S3_ENDPOINT=https://mbboakpdxgquntlohlix.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=us-east-1
# SUPABASE_STORAGE_BUCKET=session-recordings

# Resend — transactional email (booking confirmation, reminders, recording ready)
# Dashboard: https://resend.com → API Keys + Domains
RESEND_API_KEY=your-resend-api-key
# Customer-facing sender (must be on a verified Resend domain)
RESEND_FROM_EMAIL=Michele | Sacred Reference <michele@oursacredreference.com>
# Appointment emails (booking + reminders) also go to this address
PRACTITIONER_NOTIFY_EMAIL=michele@oursacredreference.com
# Required in production — Vercel Cron sends Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -hex 24
CRON_SECRET=your-random-cron-secret
